@inherits LayoutComponentBase

<div class="d-flex" style="min-height: 100vh;">
    <NavMenu />

    <div class="flex-grow-1 d-flex flex-column">
        <nav class="navbar navbar-light bg-white border-bottom px-4 py-2">
            <span class="navbar-brand mb-0 h5">Te Atiendo</span>
            <div class="d-flex align-items-center gap-2">
                @if (_authService.IsAuthenticated)
                {
                    <span class="text-muted">@_authService.CurrentUser?.Nombre</span>
                    <button class="btn btn-outline-danger btn-sm" @onclick="Logout">Cerrar sesion</button>
                }
            </div>
        </nav>

        <main class="flex-grow-1 p-4 bg-light">
            @Body
        </main>

        <footer class="bg-white border-top text-center py-2">
            <small class="text-muted">Te Atiendo 2026 - ITLA</small>
        </footer>
    </div>
</div>

@code {
    [Inject] private IAuthService _authService { get; set; } = default!;
    [Inject] private NavigationManager _nav { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _authService.LoadSession();
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await _authService.Logout();
        _nav.NavigateTo("/login", true);
    }
}