@page "/admin/moderacion"
@using TeAtiendo.Web.Services
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject ToastService Toast
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Moderacion de <span>Contenido</span></h2>
            <p class="ta-sec__sub">Revisar contenido reportado</p>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-loading"><div class="ta-spinner"></div></div>
    }
    else if (_items.Any())
    {
        <div style="display:flex;flex-direction:column;gap:14px;">
            @foreach (var item in _items)
            {
                <div class="ta-card ta-animate-fade-up" style="padding:20px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:14px;">
                            <div style="width:44px;height:44px;border-radius:12px;background:var(--warning-bg);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--warning);"><i class="bi bi-shield-exclamation"></i></div>
                            <div>
                                <div style="font-weight:700;font-size:.95rem;">@item.TipoContenido</div>
                                <div style="font-size:.75rem;color:var(--text-3);">Estado: @GetEstadoText(item.Estado)</div>
                            </div>
                        </div>
                        <span class="ta-status @GetEstadoClass(item.Estado)">@GetEstadoText(item.Estado)</span>
                    </div>
                    @if (item.Estado == 0)
                    {
                        <div style="margin-top:14px;display:flex;gap:8px;">
                            <button class="ta-btn-success" style="padding:6px 14px;font-size:.78rem;" @onclick="() => ChangeEstado(item, 1)"><i class="bi bi-check-lg"></i> Aprobar</button>
                            <button class="ta-btn-danger" style="padding:6px 14px;font-size:.78rem;" @onclick="() => ChangeEstado(item, 2)"><i class="bi bi-x-lg"></i> Rechazar</button>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-shield-check"></i></div><div class="ta-empty-state__title">Todo limpio</div><div class="ta-empty-state__sub">No hay contenido pendiente.</div></div>
    }
</section>

@code {
    private bool _isLoading = true;
    private List<ModItem> _items = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isLoading = true;
            try { var r = await ApiService.GetAsync<List<ModItem>>("api/Moderacion"); if (r != null) _items = r; }
            catch { }
            finally { _isLoading = false; }
            StateHasChanged();
        }
    }

    private async Task ChangeEstado(ModItem item, int estado)
    {
        try
        {
            await ApiService.PatchAsync<object>($"api/Moderacion/{item.Id}/estado", new { estado });
            item.Estado = estado;
            Toast.Success(estado == 1 ? "Aprobado" : "Rechazado");
            StateHasChanged();
        }
        catch { Toast.Error("Error"); }
    }

    private string GetEstadoClass(int s) => s switch { 0 => "ta-status--pendiente", 1 => "ta-status--confirmada", 2 => "ta-status--cancelada", _ => "ta-status--pendiente" };
    private string GetEstadoText(int s) => s switch { 0 => "Pendiente", 1 => "Aprobado", 2 => "Rechazado", _ => "Pendiente" };

    private class ModItem { public Guid Id { get; set; } public string TipoContenido { get; set; } = ""; public Guid ContenidoId { get; set; } public int Estado { get; set; } }
}
