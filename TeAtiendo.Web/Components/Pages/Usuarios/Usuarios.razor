@page "/admin/usuarios"
@using TeAtiendo.Web.Services
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject ToastService Toast
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Gestion de <span>Usuarios</span></h2>
            <p class="ta-sec__sub">Administrar cuentas del sistema</p>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-loading"><div class="ta-spinner"></div></div>
    }
    else if (_usuarios.Any())
    {
        <div class="ta-table-wrap">
            <table class="ta-table">
                <thead><tr><th>Usuario</th><th>Correo</th><th>Rol</th><th>Acciones</th></tr></thead>
                <tbody>
                    @foreach (var u in _usuarios)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div style="width:36px;height:36px;border-radius:50%;background:var(--primary-10);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.78rem;color:var(--primary);">@GetInitials(u.Nombre)</div>
                                    <span style="font-weight:600;">@u.Nombre</span>
                                </div>
                            </td>
                            <td style="color:var(--text-3);">@u.Correo</td>
                            <td><span class="ta-status @GetRolClass(u.Rol)">@GetRolText(u.Rol)</span></td>
                            <td>
                                <button class="ta-btn-ghost" style="padding:6px 12px;font-size:.78rem;color:var(--danger);" @onclick="() => DeleteUser(u.Id)"><i class="bi bi-trash"></i> Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-people"></i></div><div class="ta-empty-state__title">Sin usuarios</div></div>
    }
</section>

@code {
    private bool _isLoading = true;
    private List<UsuarioItem> _usuarios = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isLoading = true;
            try { var r = await ApiService.GetAsync<List<UsuarioItem>>("api/Usuarios"); if (r != null) _usuarios = r; }
            catch { }
            finally { _isLoading = false; }
            StateHasChanged();
        }
    }

    private async Task DeleteUser(Guid id)
    {
        try
        {
            await ApiService.DeleteAsync($"api/Usuarios/{id}"); Toast.Success("Usuario eliminado");
            _isLoading = true; try { var r = await ApiService.GetAsync<List<UsuarioItem>>("api/Usuarios"); if (r != null) _usuarios = r; } catch { } finally { _isLoading = false; }
            StateHasChanged();
        }
        catch { Toast.Error("Error al eliminar"); }
    }

    private string GetInitials(string? n) { if (string.IsNullOrWhiteSpace(n)) return "U"; var p = n.Split(' '); return p.Length >= 2 ? $"{p[0][0]}{p[1][0]}".ToUpper() : p[0][0].ToString().ToUpper(); }
    private string GetRolClass(int r) => r switch { 1 => "ta-status--confirmada", 2 => "ta-status--preparacion", 3 => "ta-status--pendiente", _ => "ta-status--pendiente" };
    private string GetRolText(int r) => r switch { 1 => "Cliente", 2 => "Restaurante", 3 => "Admin", _ => "Desconocido" };

    private class UsuarioItem { public Guid Id { get; set; } public string Nombre { get; set; } = ""; public string Correo { get; set; } = ""; public int Rol { get; set; } }
}
