@page "/ordenes"
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Mis <span>Ordenes</span></h2>
            <p class="ta-sec__sub">Pedidos anticipados y su estado</p>
        </div>
        <button class="ta-btn-primary" @onclick="GoToRest">
            <i class="bi bi-plus-lg"></i> Nueva Orden
        </button>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <LoadingSpinner Mode="skeleton-list" Count="4" />
    }
    else if (_ordenes.Any())
    {
        <div style="display:flex;flex-direction:column;gap:14px;">
            @foreach (var o in _ordenes.OrderByDescending(x => x.FechaOrden))
            {
                <div class="ta-card ta-animate-fade-up" style="padding:20px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                        <div style="display:flex;align-items:center;gap:14px;">
                            <div style="width:44px;height:44px;border-radius:12px;background:var(--primary-10);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--primary);">
                                <i class="bi bi-receipt"></i>
                            </div>
                            <div>
                                <div style="font-weight:700;font-size:.95rem;">Orden</div>
                                <div style="font-size:.78rem;color:var(--text-3);">
                                    <i class="bi bi-calendar3"></i> @o.FechaOrden.ToString("dd MMM yyyy, hh:mm tt")
                                </div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:12px;">
                            <StatusBadge Status="@o.Estado" />
                            <span style="font-family:'Fraunces',serif;font-weight:700;font-size:1.05rem;color:var(--primary-d);">
                                $@o.Total.ToString("N0")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <EmptyState Icon="bi-receipt" Title="Sin ordenes" Message="Aun no has hecho ninguna orden anticipada.">
            <button class="ta-btn-primary" @onclick="GoToRest"><i class="bi bi-cart-plus"></i> Hacer mi primera orden</button>
        </EmptyState>
    }
</section>

@code {
    private bool _isLoading = true;
    private string _userId = "";
    private List<OrdenDto> _ordenes = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var idResult = await SessionStorage.GetAsync<string>("userId");
                if (idResult.Success) _userId = idResult.Value ?? "";
            }
            catch { }
            await LoadOrdenes();
            StateHasChanged();
        }
    }

    private async Task LoadOrdenes()
    {
        _isLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(_userId))
            {
                var result = await ApiService.GetAsync<List<OrdenDto>>("api/Ordenes/usuario/" + _userId);
                if (result != null) _ordenes = result;
            }
        }
        catch { }
        finally { _isLoading = false; }
    }

    private void GoToRest() { Navigation.NavigateTo("/restaurantes"); }

    private class OrdenDto
    {
        public Guid Id { get; set; }
        public Guid UsuarioId { get; set; }
        public Guid RestauranteId { get; set; }
        public DateTime FechaOrden { get; set; }
        public string Estado { get; set; } = "Pendiente";
        public decimal Total { get; set; }
    }
}
