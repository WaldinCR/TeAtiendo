@page "/ordenes"
@using TeAtiendo.Web.Services
@using TeAtiendo.Web.Models.Reponses
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Mis <span>Ordenes</span></h2>
            <p class="ta-sec__sub">Pedidos anticipados y su estado</p>
        </div>
        <button class="ta-btn-primary" @onclick='() => Navigation.NavigateTo("/restaurantes")'><i class="bi bi-plus-lg"></i> Nueva Orden</button>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-loading"><div class="ta-spinner"></div></div>
    }
    else if (_ordenes != null && _ordenes.Any())
    {
        <div style="display:flex;flex-direction:column;gap:14px;">
            @foreach (var orden in _ordenes)
            {
                <div class="ta-card ta-animate-fade-up" style="padding:20px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                        <div style="display:flex;align-items:center;gap:14px;">
                            <div style="width:44px;height:44px;border-radius:12px;background:var(--primary-10);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--primary);"><i class="bi bi-receipt"></i></div>
                            <div>
                                <div style="font-weight:700;font-size:.95rem;">Orden</div>
                                <div style="font-size:.78rem;color:var(--text-3);"><i class="bi bi-calendar3"></i> @orden.Fecha.ToString("dd MMM yyyy, hh:mm tt")</div>
                            </div>
                        </div>
                        <div style="display:flex;align-items:center;gap:12px;">
                            <span class="ta-status @GetSC(orden.Estado)">@GetST(orden.Estado)</span>
                            <span style="font-family:'Fraunces',serif;font-weight:700;font-size:1.05rem;color:var(--primary-d);">$@orden.Total.ToString("N0")</span>
                        </div>
                    </div>
                    @if (orden.Detalles != null && orden.Detalles.Any())
                    {
                        <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;gap:8px;">
                            @foreach (var det in orden.Detalles)
                            {
                                <div style="background:var(--bg-warm);border-radius:10px;padding:6px 12px;font-size:.8rem;display:flex;align-items:center;gap:6px;">
                                    <i class="bi bi-egg-fried" style="color:var(--primary);"></i>
                                    <span style="font-weight:600;">Plato</span>
                                    <span style="color:var(--text-3);">x@det.Cantidad</span>
                                    <span style="color:var(--primary-d);font-weight:700;">$@det.PrecioUnitario.ToString("N0")</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-receipt"></i></div><div class="ta-empty-state__title">Sin ordenes</div><div class="ta-empty-state__sub">Aun no has hecho ninguna orden anticipada.</div><button class="ta-btn-primary" @onclick='() => Navigation.NavigateTo("/restaurantes")'><i class="bi bi-cart-plus"></i> Hacer orden</button></div>
    }
</section>

@code {
    private bool _isLoading = true;
    private Guid _userId;
    private List<OrdenResponse>? _ordenes;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { var r = await SessionStorage.GetAsync<string>("userId"); if (r.Success && Guid.TryParse(r.Value, out var uid)) _userId = uid; } catch { }
            _isLoading = true;
            try { _ordenes = await ApiService.GetAsync<List<OrdenResponse>>($"api/Ordenes/usuario/{_userId}"); }
            catch { _ordenes = new(); }
            finally { _isLoading = false; }
            StateHasChanged();
        }
    }

    private string GetSC(int s) => s switch { 0 => "ta-status--pendiente", 1 => "ta-status--preparacion", 2 => "ta-status--lista", 3 => "ta-status--entregada", 4 => "ta-status--cancelada", _ => "ta-status--pendiente" };
    private string GetST(int s) => s switch { 0 => "Pendiente", 1 => "En Preparacion", 2 => "Lista", 3 => "Entregada", 4 => "Cancelada", _ => "Pendiente" };
}
