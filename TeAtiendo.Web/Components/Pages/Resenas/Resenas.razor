@page "/resenas"
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Mis <span>Resenas</span></h2>
            <p class="ta-sec__sub">Tus opiniones sobre los restaurantes</p>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <LoadingSpinner Mode="skeleton-list" Count="3" />
    }
    else if (_resenas.Any())
    {
        <div style="display:flex;flex-direction:column;gap:14px;">
            @foreach (var r in _resenas.OrderByDescending(x => x.FechaCreacion))
            {
                <div class="ta-card ta-animate-fade-up" style="padding:20px;">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div style="width:44px;height:44px;border-radius:12px;background:var(--warning-bg);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--warning);">
                                <i class="bi bi-star-fill"></i>
                            </div>
                            <div>
                                <div style="font-weight:700;font-size:.92rem;">Restaurante</div>
                                <div style="font-size:.75rem;color:var(--text-3);">@r.FechaCreacion.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>
                        <StarRating Value="@r.Calificacion" ReadOnly="true" ShowValue="true" />
                    </div>
                    @if (!string.IsNullOrEmpty(r.Comentario))
                    {
                        <p style="margin-top:14px;padding-top:14px;border-top:1px solid var(--border);font-size:.88rem;color:var(--text-2);line-height:1.6;">@r.Comentario</p>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <EmptyState Icon="bi-star" Title="Sin resenas" Message="Aun no has dejado ninguna resena." />
    }
</section>

@code {
    private bool _isLoading = true;
    private string _userId = "";
    private List<ResenaDto> _resenas = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var idResult = await SessionStorage.GetAsync<string>("userId");
                if (idResult.Success) _userId = idResult.Value ?? "";
            }
            catch { }
            await LoadResenas();
            StateHasChanged();
        }
    }

    private async Task LoadResenas()
    {
        _isLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(_userId))
            {
                var result = await ApiService.GetAsync<List<ResenaDto>>("api/Resenas/usuario/" + _userId);
                if (result != null) _resenas = result;
            }
        }
        catch { }
        finally { _isLoading = false; }
    }

    private class ResenaDto
    {
        public Guid Id { get; set; }
        public Guid UsuarioId { get; set; }
        public Guid RestauranteId { get; set; }
        public int Calificacion { get; set; }
        public string? Comentario { get; set; }
        public DateTime FechaCreacion { get; set; }
    }
}
