@page "/restaurante/menu"
@using TeAtiendo.Web.Services
@using TeAtiendo.Web.Models.Reponses
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject ToastService Toast
@inject NotificationService Notif
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Gestionar <span>Menu</span></h2>
            <p class="ta-sec__sub">Menus y platos de tu restaurante</p>
        </div>
        <button class="ta-btn-primary" @onclick="ShowAddMenu"><i class="bi bi-plus-lg"></i> Agregar Menu</button>
    </div>
</section>

@if (_showMenuForm)
{
    <section class="ta-sec" style="padding-top:0;">
        <div class="ta-card ta-animate-slide-up" style="max-width:500px;">
            <h3 class="ta-card__title"><i class="bi bi-book" style="color:var(--primary);margin-right:6px;"></i> Nuevo Menu</h3>
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div class="ta-form-group"><label class="ta-form-label">Nombre</label><input class="ta-form-input" @bind="_menuNombre" placeholder="Menu del Dia" /></div>
                <div class="ta-form-group"><label class="ta-form-label">Descripcion</label><textarea class="ta-modal-textarea" @bind="_menuDesc"></textarea></div>
                <div style="display:flex;gap:10px;">
                    <button class="ta-btn-primary" @onclick="SaveMenu"><i class="bi bi-check-lg"></i> Guardar</button>
                    <button class="ta-btn-ghost" @onclick="() => _showMenuForm = false"><i class="bi bi-x-lg"></i> Cancelar</button>
                </div>
            </div>
        </div>
    </section>
}

@if (_showPlatoForm)
{
    <section class="ta-sec" style="padding-top:0;">
        <div class="ta-card ta-animate-slide-up" style="max-width:500px;">
            <h3 class="ta-card__title"><i class="bi bi-egg-fried" style="color:var(--primary);margin-right:6px;"></i> Nuevo Plato</h3>
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div class="ta-form-group"><label class="ta-form-label">Nombre</label><input class="ta-form-input" @bind="_platoNombre" placeholder="Ensalada Cesar" /></div>
                <div class="ta-form-group"><label class="ta-form-label">Descripcion</label><textarea class="ta-modal-textarea" @bind="_platoDesc"></textarea></div>
                <div class="ta-form-group"><label class="ta-form-label">Precio (RD$)</label><input class="ta-form-input" type="number" @bind="_platoPrecio" /></div>
                <div style="display:flex;gap:10px;">
                    <button class="ta-btn-primary" @onclick="SavePlato"><i class="bi bi-check-lg"></i> Guardar</button>
                    <button class="ta-btn-ghost" @onclick="() => _showPlatoForm = false"><i class="bi bi-x-lg"></i> Cancelar</button>
                </div>
            </div>
        </div>
    </section>
}

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-loading"><div class="ta-spinner"></div></div>
    }
    else if (_menu != null)
    {
        <div class="ta-card" style="margin-bottom:16px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="width:42px;height:42px;border-radius:12px;background:var(--primary-10);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:var(--primary);"><i class="bi bi-book"></i></div>
                    <div><div style="font-weight:700;font-size:1.05rem;">@_menu.Nombre</div><div style="font-size:.78rem;color:var(--text-3);">@_menu.Descripcion</div></div>
                </div>
                <button class="ta-btn-primary" style="padding:7px 14px;font-size:.78rem;" @onclick="ShowAddPlato"><i class="bi bi-plus"></i> Plato</button>
            </div>
            @if (_menu.Platos != null && _menu.Platos.Any())
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;">
                    @foreach (var plato in _menu.Platos)
                    {
                        <div style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--bg-warm);border-radius:14px;border:1px solid var(--border);">
                            <div style="width:40px;height:40px;border-radius:10px;background:var(--primary-10);display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0;"><i class="bi bi-egg-fried"></i></div>
                            <div style="flex:1;min-width:0;"><div style="font-weight:600;font-size:.88rem;">@plato.Nombre</div><div style="font-size:.75rem;color:var(--text-3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@plato.Descripcion</div></div>
                            <div style="font-weight:700;font-size:.88rem;color:var(--primary-d);flex-shrink:0;">$@plato.Precio.ToString("N0")</div>
                        </div>
                    }
                </div>
            }
            else
            {

                <p style="color:var(--text-3);font-size:.85rem;"><i class="bi bi-info-circle"></i> Sin platos. Agrega uno!</p>
                <button class="ta-btn-primary" style="margin-top:12px;" @onclick="ShowAddPlato"><i class="bi bi-plus-lg"></i> Agregar</button>
     }
        </div>
    }
    else
    {

        <div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-book"></i></div><div class="ta-empty-state__title">Sin menu</div><button class="ta-btn-primary" @onclick="ShowAddMenu"><i class="bi bi-plus-lg"></i> Crear menu</button></div>
    }
</section>

@code {
    private bool _isLoading = true, _showMenuForm = false, _showPlatoForm = false;
    private Guid _restauranteId;
    private MenuResponse? _menu;
    private string _menuNombre = "", _menuDesc = "", _platoNombre = "", _platoDesc = "";
    private decimal _platoPrecio = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { var r = await SessionStorage.GetAsync<string>("restauranteId"); if (r.Success && Guid.TryParse(r.Value, out var rid)) _restauranteId = rid; } catch { }
            await LoadMenu(); StateHasChanged();
        }
    }

    private async Task LoadMenu()
    {
        _isLoading = true;
        try { if (_restauranteId != Guid.Empty) _menu = await ApiService.GetAsync<MenuResponse>($"api/Menus/{_restauranteId}"); }
        catch { }
        finally { _isLoading = false; }
    }

    private void ShowAddMenu() { _menuNombre = ""; _menuDesc = ""; _showMenuForm = true; _showPlatoForm = false; }
    private void ShowAddPlato() { _platoNombre = ""; _platoDesc = ""; _platoPrecio = 0; _showPlatoForm = true; _showMenuForm = false; }

    private async Task SaveMenu()
    {
        if (string.IsNullOrWhiteSpace(_menuNombre)) { Toast.Warning("Nombre requerido"); return; }
        try
        {
            await ApiService.PostAsync<object>("api/Menus", new { nombre = _menuNombre, descripcion = _menuDesc, restauranteId = _restauranteId });
            Toast.Success("Menu creado!"); Notif.MenuActualizado(_menuNombre, "creado"); _showMenuForm = false; await LoadMenu(); StateHasChanged();
        }
        catch { Toast.Error("Error al guardar"); }
    }

    private async Task SavePlato()
    {
        if (string.IsNullOrWhiteSpace(_platoNombre) || _platoPrecio <= 0) { Toast.Warning("Nombre y precio requeridos"); return; }
        try
        {
            await ApiService.PostAsync<object>("api/Platos", new { nombre = _platoNombre, descripcion = _platoDesc, precio = _platoPrecio, menuId = _menu?.Id ?? Guid.Empty });
            Toast.Success("Plato creado!"); Notif.MenuActualizado(_platoNombre, "agregado"); _showPlatoForm = false; await LoadMenu(); StateHasChanged();
        }
        catch { Toast.Error("Error al guardar"); }
    }
}
