@page "/restaurante/dashboard"
@using TeAtiendo.Web.Services
@using TeAtiendo.Web.Models.Reponses
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Dashboard <span>Restaurante</span></h2>
            <p class="ta-sec__sub">Resumen de actividad de hoy</p>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;">
        <div class="ta-card" style="padding:20px;display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:14px;background:var(--primary-10);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--primary);"><i class="bi bi-calendar-check"></i></div>
            <div><div style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;">@_reservasHoy</div><div style="font-size:.78rem;color:var(--text-3);">Reservas hoy</div></div>
        </div>
        <div class="ta-card" style="padding:20px;display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:14px;background:var(--info-bg);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--info);"><i class="bi bi-receipt"></i></div>
            <div><div style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;">@_ordenesActivas</div><div style="font-size:.78rem;color:var(--text-3);">Ordenes activas</div></div>
        </div>
        <div class="ta-card" style="padding:20px;display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:14px;background:var(--success-bg);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--success);"><i class="bi bi-grid-3x3-gap"></i></div>
            <div><div style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;">@_mesasLibres</div><div style="font-size:.78rem;color:var(--text-3);">Mesas libres</div></div>
        </div>
        <div class="ta-card" style="padding:20px;display:flex;align-items:center;gap:16px;">
            <div style="width:48px;height:48px;border-radius:14px;background:var(--warning-bg);display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--warning);"><i class="bi bi-star-fill"></i></div>
            <div><div style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;">4.7</div><div style="font-size:.78rem;color:var(--text-3);">Rating promedio</div></div>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    <div class="ta-sec__head"><div><h2 class="ta-sec__title" style="font-size:1.3rem;">Accesos <span>Rapidos</span></h2></div></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;">
        <button class="ta-card" style="padding:24px;text-align:center;cursor:pointer;border:1.5px solid var(--border);" @onclick='() => Navigation.NavigateTo("/restaurante/reservas")'>
            <i class="bi bi-calendar-check" style="font-size:1.8rem;color:var(--primary);display:block;margin-bottom:10px;"></i>
            <div style="font-weight:700;font-size:.92rem;">Ver Reservas</div>
            <div style="font-size:.78rem;color:var(--text-3);margin-top:4px;">Gestionar reservas entrantes</div>
        </button>
        <button class="ta-card" style="padding:24px;text-align:center;cursor:pointer;border:1.5px solid var(--border);" @onclick='() => Navigation.NavigateTo("/restaurante/ordenes")'>
            <i class="bi bi-receipt" style="font-size:1.8rem;color:var(--primary);display:block;margin-bottom:10px;"></i>
            <div style="font-weight:700;font-size:.92rem;">Ver Ordenes</div>
            <div style="font-size:.78rem;color:var(--text-3);margin-top:4px;">Ordenes activas y pendientes</div>
        </button>
        <button class="ta-card" style="padding:24px;text-align:center;cursor:pointer;border:1.5px solid var(--border);" @onclick='() => Navigation.NavigateTo("/restaurante/menu")'>
            <i class="bi bi-book" style="font-size:1.8rem;color:var(--primary);display:block;margin-bottom:10px;"></i>
            <div style="font-weight:700;font-size:.92rem;">Editar Menu</div>
            <div style="font-size:.78rem;color:var(--text-3);margin-top:4px;">Platos y categorias</div>
        </button>
        <button class="ta-card" style="padding:24px;text-align:center;cursor:pointer;border:1.5px solid var(--border);" @onclick='() => Navigation.NavigateTo("/restaurante/mesas")'>
            <i class="bi bi-grid-3x3" style="font-size:1.8rem;color:var(--primary);display:block;margin-bottom:10px;"></i>
            <div style="font-weight:700;font-size:.92rem;">Gestionar Mesas</div>
            <div style="font-size:.78rem;color:var(--text-3);margin-top:4px;">Agregar y configurar mesas</div>
        </button>
    </div>
</section>

@code {
    private Guid _restauranteId;
    private int _reservasHoy = 0, _ordenesActivas = 0, _mesasLibres = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var restResult = await SessionStorage.GetAsync<string>("restauranteId");
                if (restResult.Success && Guid.TryParse(restResult.Value, out var rid)) _restauranteId = rid;
            }
            catch { }
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        try
        {
            if (_restauranteId != Guid.Empty)
            {
                try { var m = await ApiService.GetAsync<List<MesaResponse>>($"api/Mesas/restaurante/{_restauranteId}"); if (m != null) _mesasLibres = m.Count(x => x.Disponible); } catch { }
            }
        }
        catch { }
    }
}
