@page "/restaurante/reservas"
@using TeAtiendo.Web.Services
@using TeAtiendo.Web.Models.Reponses
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject ToastService Toast
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec"><div class="ta-sec__head"><div><h2 class="ta-sec__title">Reservas <span>Entrantes</span></h2><p class="ta-sec__sub">@_res.Count reservas</p></div></div></section>
<section class="ta-sec" style="padding-top:0;">
    @if(_ld){<div class="ta-loading"><div class="ta-spinner"></div></div>}
    else if(_res.Any())
    {<div class="ta-table-wrap"><table class="ta-table"><thead><tr><th>Fecha</th><th>Personas</th><th>Estado</th><th>Acciones</th></tr></thead><tbody>
        @foreach(var r in _res.OrderByDescending(x=>x.FechaReserva)){<tr>
            <td><div style="font-weight:600;">@r.FechaReserva.ToString("dd MMM yyyy")</div><div style="font-size:.75rem;color:var(--text-3);">@r.FechaReserva.ToString("hh:mm tt")</div></td>
            <td>@r.CantidadPersonas</td>
            <td><span class="ta-status @SC(r.EstadoReserva)">@ST(r.EstadoReserva)</span></td>
            <td>@if(r.EstadoReserva==0){<div style="display:flex;gap:6px;"><button class="ta-btn-success" style="padding:5px 10px;font-size:.75rem;" @onclick="()=>Up(r,1)"><i class="bi bi-check-lg"></i></button><button class="ta-btn-danger" style="padding:5px 10px;font-size:.75rem;" @onclick="()=>Up(r,3)"><i class="bi bi-x-lg"></i></button></div>}</td>
        </tr>}</tbody></table></div>}
    else{<div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-calendar-x"></i></div><div class="ta-empty-state__title">Sin reservas</div></div>}
</section>

@code {
    bool _ld=true;Guid _rid;List<ReservaResponse> _res=new();
    protected override async Task OnAfterRenderAsync(bool f){if(f){try{var r=await SessionStorage.GetAsync<string>("restauranteId");if(r.Success&&Guid.TryParse(r.Value,out var id))_rid=id;}catch{}
        _ld=true;try{var a=await ApiService.GetAsync<List<ReservaResponse>>("api/Reservas");if(a!=null)_res=a.Where(x=>x.RestauranteId==_rid).ToList();}catch{}finally{_ld=false;}StateHasChanged();}}
    async Task Up(ReservaResponse r,int s){try{await ApiService.PutAsync<object>($"api/Reservas/{r.Id}",new{id=r.Id,usuarioId=r.UsuarioId,restauranteId=r.RestauranteId,mesaId=r.MesaId,disponibilidadId=r.DisponibilidadId,fechaReserva=r.FechaReserva,cantidadPersonas=r.CantidadPersonas,estadoReserva=s});r.EstadoReserva=s;Toast.Success(s==1?"Confirmada!":"Rechazada");StateHasChanged();}catch{Toast.Error("Error");}}
    string SC(int s)=>s switch{0=>"ta-status--pendiente",1=>"ta-status--confirmada",2=>"ta-status--completada",3=>"ta-status--cancelada",_=>"ta-status--pendiente"};
    string ST(int s)=>s switch{0=>"Pendiente",1=>"Confirmada",2=>"Completada",3=>"Cancelada",_=>"Pendiente"};
}
