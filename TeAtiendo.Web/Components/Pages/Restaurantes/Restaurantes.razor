@page "/restaurantes"
@using TeAtiendo.Web.Services
@using TeAtiendo.Web.Models.Reponses
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject FavoritosService Favs
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage SessionStorage
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            @if (_showFavoritos)
            {
                <h2 class="ta-sec__title">Mis <span>Favoritos</span></h2>
            }
            else
            {
                <h2 class="ta-sec__title">Restaurantes <span>Disponibles</span></h2>
            }
            <p class="ta-sec__sub">@(_filteredRestaurantes?.Count ?? 0) restaurantes encontrados</p>
        </div>
        @if (_showFavoritos)
        {
            <button class="ta-btn-ghost" @onclick="ShowAll"><i class="bi bi-arrow-left"></i> Ver todos</button>
        }
    </div>

    <div style="margin-bottom:20px;">
        <div class="ta-search__wrap" style="max-width:100%;border-radius:var(--r-sm);height:50px;">
            <i class="ta-search__ico bi bi-search"></i>
            <input class="ta-search__input" type="search"
                   placeholder="Buscar por nombre, direccion, tipo de cocina..."
                   @bind="_searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
            @if (!string.IsNullOrEmpty(_searchQuery))
            {
                <button style="background:none;border:none;color:var(--text-3);font-size:1rem;cursor:pointer;" @onclick="ClearSearch">
                    <i class="bi bi-x-circle-fill"></i>
                </button>
            }
        </div>
    </div>

    <div style="display:flex;gap:10px;margin-bottom:16px;">
        <button class="ta-cat-pill @(!_showFavoritos ? "active" : "")" @onclick="ShowAll">
            <i class="bi bi-fire"></i> Todos
        </button>
        <button class="ta-cat-pill @(_showFavoritos ? "active" : "")" @onclick="ShowFavoritos">
            <i class="bi bi-heart-fill"></i> Favoritos (@Favs.Count)
        </button>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-r-grid">
            @for (int i = 0; i < 6; i++)
            {
                <div class="ta-sk-card">
                    <div class="ta-sk-cover ta-sk"></div>
                    <div class="ta-sk-body">
                        <div class="ta-sk" style="height:13px;width:50%"></div>
                        <div class="ta-sk" style="height:20px;width:75%"></div>
                        <div class="ta-sk" style="height:13px;width:100%"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_filteredRestaurantes != null && _filteredRestaurantes.Any())
    {
        <div class="ta-r-grid">
            @foreach (var rest in _filteredRestaurantes)
            {
                var isFav = Favs.IsFavorito(rest.Id);
                <article class="ta-rcard" @onclick="() => GoToDetalle(rest.Id)">
                    <div class="ta-rcard__img-wrap">
                        <img src="@GetImage(rest.Nombre)" alt="@rest.Nombre" loading="lazy" />
                        <div class="ta-rcard__overlay"></div>
                        <div class="ta-rcard__badges">
                            <span class="ta-badge ta-badge--green">Disponible</span>
                        </div>
                        <button class="ta-rcard__fav @(isFav ? "is-fav" : "")"
                                @onclick:stopPropagation="true"
                                @onclick="() => ToggleFav(rest.Id)">
                            <i class="bi @(isFav ? "bi-heart-fill" : "bi-heart")"></i>
                        </button>
                        <div class="ta-rcard__rating">
                            <i class="bi bi-star-fill"></i> @GetRating(rest.Nombre).ToString("0.0")
                        </div>
                        <div class="ta-rcard__logo-float">
                            <i class="bi bi-shop"></i>
                        </div>
                    </div>
                    <div class="ta-rcard__body">
                        <div class="ta-rcard__tags">
                            <span class="ta-tag">Restaurante</span>
                        </div>
                        <h3 class="ta-rcard__name">@rest.Nombre</h3>
                        <div class="ta-rcard__meta">
                            <span class="ta-rcard__meta-item">
                                <i class="bi bi-geo-alt"></i> @GetShort(rest.Direccion)
                            </span>
                            <span class="ta-rcard__meta-item">
                                <i class="bi bi-telephone"></i> @rest.Telefono
                            </span>
                        </div>
                        <div class="ta-rcard__foot">
                            <span class="ta-rcard__price">@FormatHorario(rest.HorarioApertura, rest.HorarioCierre)</span>
                            <button class="ta-btn-primary"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => GoToDetalle(rest.Id)">
                                <i class="bi bi-calendar-plus"></i> Reservar
                            </button>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="ta-empty-state">
            <div class="ta-empty-state__ico">
                @if (_showFavoritos)
                {
                    <i class="bi bi-heart"></i>
                }
                else
                {
                    <i class="bi bi-search"></i>
                }
            </div>
            <div class="ta-empty-state__title">
                @if (_showFavoritos)
                {
                    @:Sin favoritos
                }
                else
                {
                    @:Sin resultados
                }
            </div>
            <div class="ta-empty-state__sub">
                @if (_showFavoritos)
                {
                    @:Marca restaurantes con el corazon para verlos aqui.
                }
                else
                {
                    @:No encontramos restaurantes con ese criterio.
                }
            </div>
            @if (!_showFavoritos)
            {
                <button class="ta-btn-primary" @onclick="ClearSearch">
                    <i class="bi bi-arrow-counterclockwise"></i> Limpiar
                </button>
            }
        </div>
    }
</section>

@code {
    private bool _isLoading = true;
    private bool _showFavoritos = false;
    private string _searchQuery = "";
    private List<RestauranteResponse>? _restaurantes;
    private List<RestauranteResponse>? _filteredRestaurantes;

    [SupplyParameterFromQuery(Name = "buscar")]
    public string? BuscarQuery { get; set; }

    [SupplyParameterFromQuery(Name = "favoritos")]
    public string? FavoritosQuery { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!string.IsNullOrEmpty(BuscarQuery)) _searchQuery = BuscarQuery;
            if (FavoritosQuery == "true") _showFavoritos = true;
            Favs.OnChange += () => InvokeAsync(() => { Filter(); StateHasChanged(); });
            await LoadRestaurantes();
            StateHasChanged();
        }
    }

    private async Task LoadRestaurantes()
    {
        _isLoading = true;
        try
        {
            var r = await ApiService.GetAsync<RestauranteApiResponse>("api/Restaurantes");
            if (r?.Data != null)
            {
                _restaurantes = r.Data;
                Filter();
            }
        }
        catch { }
        finally { _isLoading = false; }
    }

    private void Filter()
    {
        if (_restaurantes == null) return;

        var list = _restaurantes.AsEnumerable();

        if (_showFavoritos)
            list = list.Where(r => Favs.IsFavorito(r.Id));

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var q = _searchQuery.ToLower();
            list = list.Where(r =>
                (r.Nombre?.ToLower().Contains(q) ?? false) ||
                (r.Direccion?.ToLower().Contains(q) ?? false) ||
                (r.Telefono?.Contains(q) ?? false));
        }

        _filteredRestaurantes = list.ToList();
    }

    private void HandleSearch() { Filter(); StateHasChanged(); }
    private void ClearSearch() { _searchQuery = ""; Filter(); }
    private void ShowAll() { _showFavoritos = false; Filter(); }
    private void ShowFavoritos() { _showFavoritos = true; Filter(); }
    private void GoToDetalle(Guid id) { Navigation.NavigateTo($"/restaurantes/{id}"); }
    private void ToggleFav(Guid id) { Favs.Toggle(id); Filter(); }

    private string GetImage(string? n)
    {
        var imgs = new[] {
            "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=700&q=80",
            "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=700&q=80",
            "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=700&q=80",
            "https://images.unsplash.com/photo-1512621776951-a57141f2eefd?w=700&q=80",
            "https://images.unsplash.com/photo-1544025162-d76694265947?w=700&q=80",
            "https://images.unsplash.com/photo-1565299507177-b0ac66763828?w=700&q=80"
        };
        return imgs[Math.Abs((n ?? "").GetHashCode()) % imgs.Length];
    }

    private string GetShort(string? d)
    {
        if (string.IsNullOrEmpty(d)) return "Santo Domingo";
        var parts = d.Split(',');
        return parts.Length > 1 ? parts[^1].Trim() : d;
    }

    private string FormatHorario(string? a, string? c)
    {
        if (string.IsNullOrEmpty(a) || string.IsNullOrEmpty(c)) return "";
        return (a.Length >= 5 ? a.Substring(0, 5) : a) + " - " + (c.Length >= 5 ? c.Substring(0, 5) : c);
    }

    private double GetRating(string? n) => 4.0 + Math.Abs((n ?? "").GetHashCode() % 10) * 0.1;
}
