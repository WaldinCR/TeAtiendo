@page "/admin/auditoria"
@using TeAtiendo.Web.Services
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Logs de <span>Auditoria</span></h2>
            <p class="ta-sec__sub">Registro de actividades del sistema</p>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-loading"><div class="ta-spinner"></div></div>
    }
    else if (_logs.Any())
    {
        <div class="ta-table-wrap">
            <table class="ta-table">
                <thead><tr><th>Fecha</th><th>Usuario</th><th>Accion</th><th>Entidad</th><th>Detalles</th></tr></thead>
                <tbody>
                    @foreach (var log in _logs.OrderByDescending(l => l.Fecha))
                    {
                        <tr>
                            <td style="font-size:.82rem;color:var(--text-3);">@log.Fecha.ToString("dd MMM yyyy HH:mm")</td>
                            <td style="font-weight:600;">@log.Usuario</td>
                            <td>
                                <span class="ta-status @GetActionClass(log.Accion)">@log.Accion</span>
                            </td>
                            <td>@log.Entidad</td>
                            <td style="font-size:.82rem;color:var(--text-3);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@log.Detalles</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-journal-text"></i></div><div class="ta-empty-state__title">Sin logs</div><div class="ta-empty-state__sub">No hay registros de auditoria aun.</div></div>
    }
</section>

@code {
    private bool _isLoading = true;
    private List<AuditLog> _logs = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await Load(); StateHasChanged(); }
    }

    private async Task Load()
    {
        _isLoading = true;
        try { var r = await ApiService.GetAsync<List<AuditLog>>("api/Auditoria"); if (r != null) _logs = r; }
        catch { }
        finally { _isLoading = false; }
    }

    private string GetActionClass(string? a) => (a?.ToLower()) switch { "crear" or "create" => "ta-status--confirmada", "editar" or "update" => "ta-status--preparacion", "eliminar" or "delete" => "ta-status--cancelada", "login" => "ta-status--lista", _ => "ta-status--pendiente" };

    private class AuditLog { public Guid Id { get; set; } public DateTime Fecha { get; set; } public string Usuario { get; set; } = ""; public string Accion { get; set; } = ""; public string Entidad { get; set; } = ""; public string? Detalles { get; set; } }
}
