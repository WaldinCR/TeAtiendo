@page "/admin/auditoria"
@using TeAtiendo.Web.Services
@layout TeAtiendo.Web.Components.Layout.MainLayout
@inject IApiService ApiService
@rendermode InteractiveServer

<section class="ta-sec">
    <div class="ta-sec__head">
        <div>
            <h2 class="ta-sec__title">Logs de <span>Auditoria</span></h2>
            <p class="ta-sec__sub">Registro de actividades del sistema</p>
        </div>
    </div>
</section>

<section class="ta-sec" style="padding-top:0;">
    @if (_isLoading)
    {
        <div class="ta-loading"><div class="ta-spinner"></div></div>
    }
    else if (_logs.Any())
    {
        <div class="ta-table-wrap">
            <table class="ta-table">
                <thead><tr><th>Fecha</th><th>Admin</th><th>Modulo</th><th>Detalles</th></tr></thead>
                <tbody>
                    @foreach (var log in _logs)
                    {
                        <tr>
                            <td style="font-size:.82rem;color:var(--text-3);">@log.Fecha.ToString("dd MMM yyyy HH:mm")</td>
                            <td style="font-weight:600;">Admin</td>
                            <td><span class="ta-status ta-status--preparacion">@log.Modulo</span></td>
                            <td style="font-size:.82rem;color:var(--text-3);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@log.Descripcion</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="ta-empty-state"><div class="ta-empty-state__ico"><i class="bi bi-journal-text"></i></div><div class="ta-empty-state__title">Sin logs</div></div>
    }
</section>

@code {
    private bool _isLoading = true;
    private List<AuditLog> _logs = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isLoading = true;
            // GET api/Auditorias
            try { var r = await ApiService.GetAsync<List<AuditLog>>("api/Auditorias"); if (r != null) _logs = r; }
            catch { }
            finally { _isLoading = false; }
            StateHasChanged();
        }
    }

    private class AuditLog
    {
        public Guid Id { get; set; }
        public Guid AdminId { get; set; }
        public string Modulo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public DateTime Fecha { get; set; }
    }
}
