@page "/"
@rendermode InteractiveServer

@if (!_loaded)
{
    <LoadingSpinner Message="Cargando..." />
}
else if (_authService.IsAuthenticated)
{
    <div class="text-center mt-5">
        <h1 class="display-4">Bienvenido a Te Atiendo</h1>
        <p class="lead text-muted">Plataforma de Reservas y Ordenes de Restaurantes</p>

        <div class="mt-4">
            <h4>Hola, @_authService.CurrentUser?.Nombre</h4>
            <p class="text-muted">Que deseas hacer hoy?</p>

            <div class="row justify-content-center mt-4 g-3">
                <div class="col-md-3">
                    <a href="/restaurantes" class="card text-decoration-none h-100">
                        <div class="card-body text-center">
                            <h5>Restaurantes</h5>
                            <p class="text-muted">Buscar y explorar</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/reservas" class="card text-decoration-none h-100">
                        <div class="card-body text-center">
                            <h5>Reservas</h5>
                            <p class="text-muted">Gestionar reservas</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/ordenes" class="card text-decoration-none h-100">
                        <div class="card-body text-center">
                            <h5>Ordenes</h5>
                            <p class="text-muted">Pedidos anticipados</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center mt-5">
        <h1 class="display-4">Bienvenido a Te Atiendo</h1>
        <p class="lead text-muted">Plataforma de Reservas y Ordenes de Restaurantes</p>
        <div class="mt-4">
            <a href="/login" class="btn btn-primary btn-lg me-2">Iniciar Sesion</a>
            <a href="/register" class="btn btn-outline-primary btn-lg">Registrarse</a>
        </div>
    </div>
}

@code {
    [Inject] private IAuthService _authService { get; set; } = default!;

    private bool _loaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _authService.LoadSession();
            _loaded = true;
            StateHasChanged();
        }
    }
}