@page "/pagos"
@rendermode InteractiveServer

<h3>Pagos</h3>

<ErrorAlert Message="@_error" />

@if (_success)
{
    <div class="alert alert-success">Pago procesado exitosamente.</div>
}

@if (_loading)
{
    <LoadingSpinner />
}
else if (_ordenesPendientes is null || _ordenesPendientes.Count == 0)
{
    <div class="alert alert-info">No tienes ordenes pendientes de pago.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Total</th>
                <th>Metodo de pago</th>
                <th>Accion</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in _ordenesPendientes)
            {
                <tr>
                    <td>@o.Fecha.ToString("dd/MM/yyyy")</td>
                    <td>$@o.Total.ToString("N2")</td>
                    <td>
                        <select class="form-select form-select-sm" @onchange="(e) => SetMetodo(o.Id, e)">
                            <option value="1">Efectivo</option>
                            <option value="2">Tarjeta Credito</option>
                            <option value="3">Tarjeta Debito</option>
                            <option value="4">Transferencia</option>
                        </select>
                    </td>
                    <td>
                        <button class="btn btn-success btn-sm" @onclick="() => Pagar(o.Id)">Pagar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Inject] private IApiService _api { get; set; } = default!;
    [Inject] private IAuthService _auth { get; set; } = default!;

    private List<OrdenResponse>? _ordenesPendientes;
    private Dictionary<Guid, int> _metodos = new();
    private bool _loading = true;
    private bool _success = false;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (_auth.CurrentUser is not null)
        {
            var ordenes = await _api.GetAsync<List<OrdenResponse>>($"api/Ordenes/usuario/{_auth.CurrentUser.Id}");
            _ordenesPendientes = ordenes?.Where(o => o.Estado == 1).ToList();
        }
        _loading = false;
    }

    private void SetMetodo(Guid ordenId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
            _metodos[ordenId] = val;
    }

    private async Task Pagar(Guid ordenId)
    {
        _error = string.Empty;
        _success = false;

        int metodo = _metodos.ContainsKey(ordenId) ? _metodos[ordenId] : 1;

        var pago = new
        {
            OrdenId = ordenId,
            MetodoPago = metodo,
            Monto = 0,
            EstadoPago = 1
        };

        var result = await _api.PostAsync<PagoResponse>("api/Pagos", pago);

        if (result is not null)
        {
            _success = true;
            _ordenesPendientes = _ordenesPendientes?.Where(o => o.Id != ordenId).ToList();
        }
        else
        {
            _error = "Error al procesar el pago";
        }
    }
}