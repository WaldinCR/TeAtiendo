@* EmptyState.razor — Estado vacio reutilizable *@

<div class="ta-empty-state ta-animate-fade-up">
    <div class="ta-empty-state__ico">
        <i class="bi @Icon"></i>
    </div>
    <div class="ta-empty-state__title">@Title</div>
    <p class="ta-empty-state__sub">@Message</p>
    @if (ChildContent != null)
    {
        <div style="margin-top:8px;">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "bi-inbox";
    [Parameter] public string Title { get; set; } = "Sin resultados";
    [Parameter] public string Message { get; set; } = "No hay datos para mostrar.";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
