@* RestauranteCard.razor — Card de restaurante con GUID IDs *@
@inject NavigationManager Navigation

<article class="ta-rcard" tabindex="0" @onclick="GoToDetail">
    <div class="ta-rcard__img-wrap">
        @if (!string.IsNullOrEmpty(ImageUrl))
        {
            <img src="@ImageUrl" alt="@Nombre" loading="lazy" />
        }
        else
        {
            <div style="width:100%;height:100%;background:linear-gradient(135deg, #EDE5DA, #D4C4B8);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-shop" style="font-size:2.5rem;color:var(--text-3);"></i>
            </div>
        }
        <div class="ta-rcard__overlay"></div>

        <div class="ta-rcard__badges">
            @if (MesasDisponibles > 0)
            {
                <span class="ta-badge ta-badge--green">
                    <i class="bi bi-circle-fill" style="font-size:.45rem;"></i> Disponible
                </span>
            }
            else
            {
                <span class="ta-badge ta-badge--red">
                    <i class="bi bi-x-circle" style="font-size:.6rem;"></i> Lleno
                </span>
            }
        </div>

        <button class="ta-rcard__fav @(_isFav ? "is-fav" : "")"
                @onclick="ToggleFav" @onclick:stopPropagation="true">
            <i class="bi @(_isFav ? "bi-heart-fill" : "bi-heart")"></i>
        </button>

        @if (Rating > 0)
        {
            <div class="ta-rcard__rating">
                <i class="bi bi-star-fill"></i> @Rating.ToString("0.0") - @TotalResenas
            </div>
        }

        <div class="ta-rcard__logo-float">
            <i class="bi @GetCategoryIcon()"></i>
        </div>
    </div>

    <div class="ta-rcard__body">
        @if (Tags != null && Tags.Any())
        {
            <div class="ta-rcard__tags">
                @foreach (var tag in Tags.Take(3))
                {
                    <span class="ta-tag">@tag</span>
                }
            </div>
        }

        <h3 class="ta-rcard__name">@Nombre</h3>

        <div class="ta-rcard__meta">
            @if (!string.IsNullOrEmpty(Direccion))
            {
                <span class="ta-rcard__meta-item">
                    <i class="bi bi-geo-alt"></i> @Direccion
                </span>
            }
            @if (!string.IsNullOrEmpty(Horario))
            {
                <span class="ta-rcard__meta-item">
                    <i class="bi bi-clock"></i> @Horario
                </span>
            }
            @if (MesasDisponibles > 0)
            {
                <span class="ta-rcard__meta-item">
                    <i class="bi bi-grid-3x3-gap"></i> @MesasDisponibles mesas
                </span>
            }
        </div>

        <div class="ta-rcard__foot">
            @if (!string.IsNullOrEmpty(Telefono))
            {
                <span class="ta-rcard__price">
                    <i class="bi bi-telephone" style="font-size:.75rem;"></i> @Telefono
                </span>
            }
            <button class="ta-btn-primary" @onclick="GoToDetail" @onclick:stopPropagation="true">
                <i class="bi bi-calendar-plus"></i> Reservar
            </button>
        </div>
    </div>
</article>

@code {
    [Parameter] public string RestauranteId { get; set; } = "";
    [Parameter] public string Nombre { get; set; } = "";
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? Direccion { get; set; }
    [Parameter] public string? Telefono { get; set; }
    [Parameter] public string? Horario { get; set; }
    [Parameter] public double Rating { get; set; }
    [Parameter] public int TotalResenas { get; set; }
    [Parameter] public int MesasDisponibles { get; set; }
    [Parameter] public List<string>? Tags { get; set; }
    [Parameter] public string? Categoria { get; set; }

    private bool _isFav = false;

    private void GoToDetail()
    {
        Navigation.NavigateTo("/restaurantes/" + RestauranteId);
    }

    private void ToggleFav()
    {
        _isFav = !_isFav;
    }

    private string GetCategoryIcon()
    {
        var cat = Categoria?.ToLower() ?? "";
        return cat switch
        {
            "italiana" or "pasta" => "bi-cup-hot",
            "japonesa" or "sushi" => "bi-flower1",
            "mexicana" => "bi-fire",
            "carnes" or "parrilla" or "bbq" => "bi-fire",
            "vegana" or "vegetariana" => "bi-tree",
            "francesa" => "bi-cup-straw",
            "criolla" or "dominicana" => "bi-sun",
            "mariscos" or "seafood" => "bi-water",
            "postres" => "bi-cake2",
            "cafe" or "brunch" => "bi-cup-hot-fill",
            _ => "bi-shop"
        };
    }
}
